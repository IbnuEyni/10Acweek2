# LLM Provider Configuration
# Choose one provider and set its API key

# DeepSeek (Recommended - Cheap & Powerful)
# Get key: https://platform.deepseek.com/api_keys
# Cost: ~$0.02 per audit
DEEPSEEK_API_KEY=your_deepseek_key_here

# Groq (Fast & Free)
# Get key: https://console.groq.com/keys
# Free tier: 30 requests/minute
GROQ_API_KEY=your_groq_key_here

# Google Gemini (For Vision Inspector - Optional)
# Get key: https://aistudio.google.com/app/apikey
# Free tier: 1,500 requests/day
GOOGLE_API_KEY=your_google_key_here

# OpenAI (Premium)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# Anthropic (Premium)
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# LangSmith Observability (Required for tracing)
# Get key: https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=automaton-auditor
LANGSMITH_API_KEY=your_langsmith_key_here

# Model Configuration
LLM_PROVIDER=deepseek
DEFAULT_LLM_MODEL=deepseek-chat
DEFAULT_TEMPERATURE=0.0
