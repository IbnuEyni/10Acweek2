# LLM Provider Keys (Choose one or more)

# OpenAI (Paid)
# OPENAI_API_KEY=your_openai_key_here

# Anthropic (Paid)
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Groq (FREE & FAST - Recommended)
# Get key: https://console.groq.com/keys
# GROQ_API_KEY=gsk_xxxxxxxxxxxxx

# Google Gemini (Free tier available)
# Get key: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxx

# Together AI (Free $25 credits)
# Get key: https://api.together.xyz/settings/api-keys
# TOGETHER_API_KEY=xxxxxxxxxxxxx

# Ollama (100% Free - Local)
# Install: https://ollama.com/download
# OLLAMA_BASE_URL=http://localhost:11434

# LangSmith Observability (Required)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=automaton-auditor
LANGSMITH_API_KEY=your_langsmith_key_here

# Optional: Model Configuration
# Choose based on your provider:
# - OpenAI: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# - Groq: llama-3.1-70b-versatile, mixtral-8x7b-32768
# - Google: gemini-1.5-pro, gemini-1.5-flash
# - Together: meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
# - Ollama: llama3.1:8b, mistral, qwen2.5
DEFAULT_LLM_MODEL=gpt-4o
DEFAULT_TEMPERATURE=0.0
